{
  "name": "jajang-mobile",
  "version": "0.1.0",
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "ios": "expo run:ios",
    "android": "bash scripts/setup-adb-reverse.sh && expo run:android",
    "reverse": "bash scripts/setup-adb-reverse.sh",
    "type-check": "tsc --noEmit",
    "lint": "eslint src --ext .ts,.tsx",
    "qa:init": "mobile-qa-tour init --out .",
    "qa:monkey": "mobile-qa-tour monkey --package com.jajang.app --events 1000 --output ../../docs/qa --pct-syskeys 0 --pct-nav 0",
    "qa:tour": "mobile-qa-tour tour --config ./qa.config.json"
  },
  "dependencies": {
    "@invertase/react-native-apple-authentication": "^2.3.0",
    "@react-native-async-storage/async-storage": "^2.0.0",
    "@react-native-google-signin/google-signin": "^13.0.0",
    "@react-navigation/bottom-tabs": "^7.0.0",
    "@react-navigation/native": "^7.0.0",
    "@react-navigation/native-stack": "^7.0.0",
    "axios": "^1.7.0",
    "events": "^3.3.0",
    "expo": "^55.0.17",
    "expo-audio": "~55.0.14",
    "expo-file-system": "~55.0.19",
    "expo-secure-store": "~55.0.13",
    "expo-status-bar": "~55.0.5",
    "expo-web-browser": "~55.0.14",
    "jwt-decode": "^4.0.0",
    "react": "19.2.0",
    "react-native": "^0.83.6",
    "react-native-purchases": "^7.0.0",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "mobile-qa-tour": "*",
    "@babel/core": "^7.24.0",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^12.0.0",
    "@types/react": "~18.3.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "babel-plugin-module-resolver": "^5.0.0",
    "eslint": "^9.0.0",
    "react-test-renderer": "^19.2.5",
    "typescript": "~5.3.0",
    "vitest": "^3.0.0"
  }
}
